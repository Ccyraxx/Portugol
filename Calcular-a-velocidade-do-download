programa
{
    funcao inicio()
    {
        real t_a, v_l, t_D
        
        escreva("Digite o tamanho do arquivo para download (em MB): ")
        leia(t_a)
        escreva("Digite a velocidade da internet (em Mbps): ")
        leia(v_l)

        t_D = (t_a * 8) / v_l

        t_D = t_D / 60

        escreva("Tempo aproximado de download: ", t_D, " minutos\n")
    }
}
