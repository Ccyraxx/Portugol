programa
{
	
	funcao inicio()
	{
		
     real l1, l2, diagonal

   escreva("Digite o comprimento da casa (em metros): ")
   leia(l1)

   escreva("Digite a largura da casa (em metros): ")
   leia(l2)

   diagonal = l1 * l1 + l2 * l2

   escreva("A quantidade mínima de fio a ser comprada é: ", diagonal, " metros.")
	}
}
